generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  persona     String
  goals       String
  limits      String
  avatarUrl            String?  // URL of the AI-generated avatar image (populated by Avatar Engine)
  
  // [NEW] Canonical Identity Fields
  canonicalDescription String?
  visualTraits         String?  // Storing as JSON string
  styleProfile         String?
  negativePrompt       String?
  seed                 Int?     // Fixed generation seed
  referenceImageUrl    String?  // URL of the canonical avatar, used for img2img prompting if supported
  
  userId               Int?     // [NEW] Association with User
  createdAt            DateTime @default(now())

  user                 User?    @relation(fields: [userId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String?  @unique
  plan      Plan     @default(FREE)
  characters Character[]
  stories    Story[]
  createdAt DateTime @default(now())
}

enum Plan {
  FREE
  PRO
  ADMIN
}

model Story {
  id             Int      @id @default(autoincrement())
  title          String
  genre          String   @default("fantasia urbana")
  scenario       String   @default("")
  synopsis       String?
  status         String   @default("in_progress")
  worldState     Json
  characterIds   Json     @default("[]")
  lastActivityAt DateTime @default(now())
  messageCount   Int      @default(0)
  userId         Int?     // [NEW] Association with User
  createdAt      DateTime @default(now())
  
  // [NEW] Publishing Fields
  publishStatus  String   @default("draft") // "draft" | "published"
  coverImageUrl  String?
  comicStripUrl  String?

  scenes         Scene[]
  episodes       Episode[]
  user           User?    @relation(fields: [userId], references: [id])
}

model Scene {
  id          Int      @id @default(autoincrement())
  storyId     Int
  chapter     Int
  text        String
  playerInput String?
  imageStatus String   @default("none") // "none" | "pending" | "ready" | "error"
  imageUrl    String?
  imagePrompt String?
  
  // [NEW] Generation Tracking
  finalPrompt       String?
  negativePrompt    String?
  referenceImageUrl String?
  seed              Int?
  providerModel     String?
  styleProfile      String?
  createdAt   DateTime @default(now())

  episodeId   Int?

  story   Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  @@index([storyId])
  @@index([episodeId])
}

model Episode {
  id            Int      @id @default(autoincrement())
  storyId       Int
  title         String   @default("Nuevo Episodio")
  episodeNumber Int
  publishStatus String   @default("draft") // "draft" | "published"
  publishedAt   DateTime?
  createdAt     DateTime @default(now())

  story         Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  scenes        Scene[]

  @@index([storyId])
}

