# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev:       DATABASE_URL="file:./prisma/dev.db"
# Production (pg): DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DATABASE_URL=

# ─── Ollama LLM (story engine) ────────────────────────────────────────────────
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_HOST=https://ollama.com

# ─── Image Generation (Replicate) ─────────────────────────────────────────────
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# Which provider to use. Only "replicate" is supported for now.
AVATAR_PROVIDER=replicate

# Optional: override default model (flux-schnell ~$0.003/image, ~4s)
# AVATAR_MODEL=black-forest-labs/flux-schnell

# ─── Asset Storage (S3-compatible) ────────────────────────────────────────────
# Required in production for comic-strip image persistence.
# Leave blank in local dev — files will be written to public/comics/ instead.
#
# Compatible providers:
#   AWS S3       → region = us-east-1 (or your bucket region)
#   Cloudflare R2→ use R2 endpoint as CDN_BASE_URL
#   MinIO        → works with any S3-compatible endpoint
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional: CloudFront or custom CDN domain in front of your S3 bucket.
# If blank, public S3 virtual-hosted URLs are used.
# Example: https://cdn.yourdomain.com
CDN_BASE_URL=

# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# Set this in your frontend host (Vercel, Netlify, Cloudflare Pages…)
# This is the public URL of your deployed backend.
VITE_API_BASE_URL=https://your-backend.railway.app

# ─── Security ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Required in production. Example: https://frontend.vercel.app
ALLOWED_ORIGINS=

# Optional: Rate Limiting overrides
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_MAX_AI_REQUESTS=10

